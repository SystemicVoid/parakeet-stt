[Unit]
Description=Parakeet PTT Client
After=graphical-session.target network.target
Wants=graphical-session.target

[Service]
# UPDATE THESE PATHS
WorkingDirectory=/path/to/parakeet-stt/parakeet-ptt
ExecStart=/path/to/parakeet-stt/parakeet-ptt/target/release/parakeet-ptt
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
